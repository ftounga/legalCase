<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="034-create-case-file-shares" author="ailegalcase">
        <createTable tableName="case_file_shares">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="case_file_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_shares_case_file"
                             references="case_files(id)"/>
            </column>
            <column name="token" type="VARCHAR(64)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_share_token"/>
            </column>
            <column name="expires_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_shares_user"
                             references="users(id)"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="revoked_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <createIndex tableName="case_file_shares" indexName="idx_shares_case_file_id">
            <column name="case_file_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
