<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="032-create-analysis-qa-snapshots" author="legalcase">
        <createTable tableName="analysis_qa_snapshots">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="analysis_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_qa_snapshot_analysis"
                             references="case_analyses(id)"
                             deleteCascade="true"/>
            </column>
            <column name="order_index" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="question_text" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="answer_text" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamptz">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="analysis_qa_snapshots" indexName="idx_qa_snapshot_analysis_id">
            <column name="analysis_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
