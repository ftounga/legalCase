<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="027-1-add-last-document-deleted-at" author="ailegalcase">
        <addColumn tableName="case_files">
            <column name="last_document_deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </addColumn>
    </changeSet>

    <changeSet id="027-2-create-audit-logs" author="ailegalcase">
        <createTable tableName="audit_logs">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="workspace_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_audit_log_workspace"
                             references="workspaces(id)"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_audit_log_user"
                             references="users(id)"/>
            </column>
            <column name="case_file_id" type="UUID">
                <constraints nullable="true"/>
            </column>
            <column name="action" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="metadata" type="CLOB"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="audit_logs" indexName="idx_audit_logs_workspace_id">
            <column name="workspace_id"/>
        </createIndex>
        <createIndex tableName="audit_logs" indexName="idx_audit_logs_case_file_id">
            <column name="case_file_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
