<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="007-create-documents" author="ailegalcase">
        <createTable tableName="documents">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="case_file_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_documents_case_file_id"
                             references="case_files(id)"/>
            </column>
            <column name="uploaded_by_user_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_documents_uploaded_by_user_id"
                             references="users(id)"/>
            </column>
            <column name="original_filename" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="content_type" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="file_size" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="storage_key" type="varchar(1024)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="documents" indexName="idx_documents_case_file_id">
            <column name="case_file_id"/>
        </createIndex>

        <createIndex tableName="documents" indexName="idx_documents_uploaded_by_user_id">
            <column name="uploaded_by_user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
