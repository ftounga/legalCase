<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="030-create-analysis-documents" author="dev">
        <createTable tableName="analysis_documents">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="analysis_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_analysis_documents_analysis"
                             references="case_analyses(id)"
                             deleteCascade="true"/>
            </column>
            <column name="document_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="document_name" type="varchar(500)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="analysis_documents"
                             columnNames="analysis_id, document_id"
                             constraintName="uq_analysis_document"/>

        <createIndex tableName="analysis_documents" indexName="idx_analysis_documents_analysis_id">
            <column name="analysis_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
