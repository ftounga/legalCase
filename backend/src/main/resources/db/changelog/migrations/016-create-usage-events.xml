<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="016-1" author="system">
        <createTable tableName="usage_events">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="case_file_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
            <column name="tokens_input" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="tokens_output" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="estimated_cost" type="decimal(12,6)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamptz">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="usage_events" indexName="idx_usage_events_case_file_id">
            <column name="case_file_id"/>
        </createIndex>

        <createIndex tableName="usage_events" indexName="idx_usage_events_user_id">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
