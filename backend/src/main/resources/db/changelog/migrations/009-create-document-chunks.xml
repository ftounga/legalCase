<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="009-create-document-chunks" author="legalcase">
        <createTable tableName="document_chunks">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="extraction_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_chunk_extraction"
                             references="document_extractions(id)"/>
            </column>
            <column name="chunk_index" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="chunk_text" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="token_count" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="chunk_metadata" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="document_chunks" indexName="idx_document_chunks_extraction_id">
            <column name="extraction_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
