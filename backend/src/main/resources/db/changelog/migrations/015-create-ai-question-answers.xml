<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="015-add-answered-at-to-ai-questions" author="ailegalcase">
        <addColumn tableName="ai_questions">
            <column name="answered_at" type="TIMESTAMP WITH TIME ZONE"/>
        </addColumn>
    </changeSet>

    <changeSet id="015-create-ai-question-answers" author="ailegalcase">
        <createTable tableName="ai_question_answers">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="ai_question_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_ai_question_answers_question"
                             references="ai_questions(id)"/>
            </column>
            <column name="answered_by_user_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_ai_question_answers_user"
                             references="users(id)"/>
            </column>
            <column name="answer_text" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="ai_question_answers" indexName="idx_ai_question_answers_question_id">
            <column name="ai_question_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
