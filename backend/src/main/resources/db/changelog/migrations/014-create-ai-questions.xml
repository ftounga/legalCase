<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="014-create-ai-questions" author="ailegalcase">
        <createTable tableName="ai_questions">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="case_file_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_ai_questions_case_file"
                             references="case_files(id)"/>
            </column>
            <column name="question_text" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="order_index" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="ai_questions" indexName="idx_ai_questions_case_file_id">
            <column name="case_file_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
