<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="004-create-workspaces" author="ailegalcase">
        <createTable tableName="workspaces">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="slug" type="varchar(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="owner_user_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_workspaces_owner_user_id"
                             references="users(id)"/>
            </column>
            <column name="billing_email" type="varchar(255)"/>
            <column name="plan_code" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="workspaces" indexName="idx_workspaces_owner_user_id">
            <column name="owner_user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
