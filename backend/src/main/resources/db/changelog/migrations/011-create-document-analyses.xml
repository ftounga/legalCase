<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="011-create-document-analyses" author="legalcase">
        <createTable tableName="document_analyses">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="document_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_document_analysis_document"
                             references="documents(id)"/>
            </column>
            <column name="extraction_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_document_analysis_extraction"
                             references="document_extractions(id)"/>
            </column>
            <column name="analysis_status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="analysis_result" type="TEXT"/>
            <column name="model_used" type="VARCHAR(100)"/>
            <column name="prompt_tokens" type="INTEGER"/>
            <column name="completion_tokens" type="INTEGER"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="document_analyses" indexName="idx_document_analyses_extraction_id">
            <column name="extraction_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
