<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="022-1" author="ailegalcase">
        <addColumn tableName="auth_accounts">
            <column name="password_hash" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="022-2" author="ailegalcase">
        <addColumn tableName="auth_accounts">
            <column name="email_verified" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="022-3" author="ailegalcase">
        <createTable tableName="email_verification_tokens">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_email_verif_user" references="users(id)"/>
            </column>
            <column name="token" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_email_verif_token"/>
            </column>
            <column name="expires_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="used_at" type="TIMESTAMPTZ"/>
            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="022-4" author="ailegalcase">
        <createTable tableName="password_reset_tokens">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_pwd_reset_user" references="users(id)"/>
            </column>
            <column name="token" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_pwd_reset_token"/>
            </column>
            <column name="expires_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="used_at" type="TIMESTAMPTZ"/>
            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
